# Google Gemini API Key for Server-Side Interactions (Keep hidden from the client)
# Note: Google AI Studio issues API keys with various prefixes (e.g., 'AIzaSy', 'AQ.').
# Do not implement or rely on prefix-based validation (like startsWith('AIzaSy')).
# Only validate keys by testing them against the actual Gemini API.
GEMINI_API_KEY=

# You can add multiple free tier API keys to bypass rate limits (fallback automatically)
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=

# Hermes Gateway Configuration
HERMES_GATEWAY_URL=
HERMES_API_TOKEN=

# Piper TTS (Local upgrade - requires local piper binary/model)
PIPER_ENABLED=true
PIPER_PATH=piper
PIPER_MODEL=en_GB-jenny_dioco-medium.onnx

# Faster-Whisper local sidecar (Speech to Text)
STT_SIDECAR_URL=http://localhost:8643

# Free Claude Code (fcc-server) Proxy gateway configuration
FCC_SERVER_URL=http://localhost:8082

# Voice Mode Provider API Keys (Used when routing through fcc-server or direct)
GROQ_API_KEY=
KIMI_API_KEY=
OLLAMA_API_KEY=
OPENROUTER_API_KEY=

