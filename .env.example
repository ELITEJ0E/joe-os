# Google Gemini API Key for Server-Side Interactions (Keep hidden from the client)
# Note: Google AI Studio issues API keys with various prefixes (e.g., 'AIzaSy', 'AQ.').
# Do not implement or rely on prefix-based validation (like startsWith('AIzaSy')).
# Only validate keys by testing them against the actual Gemini API.
GEMINI_API_KEY=

# You can add multiple free tier API keys to bypass rate limits (fallback automatically)
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
